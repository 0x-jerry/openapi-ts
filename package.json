{
  "name": "@0x-jerry/openapi-ts",
  "version": "2.0.5",
  "description": "This package provide a quick way to transform OpenAPI schema or Swagger schema to client typescript code.",
  "type": "module",
  "repository": {
    "url": "https://github.com/0x-jerry/openapi-ts"
  },
  "bin": {
    "o2ts": "dist/cli/index.mjs"
  },
  "exports": {
    ".": "./dist/src/index.mjs"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui --coverage",
    "build": "tsdown",
    "g:test": "tsx test/e2e.ts",
    "release": "x-release",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "optionalDependencies": {
    "axios": "^1.15.2",
    "ky": "^2.0.2"
  },
  "dependencies": {
    "@0x-jerry/silver": "^1.2.4",
    "@0x-jerry/utils": "^6.4.2",
    "fs-extra": "^11.3.4",
    "json-schema-to-typescript": "^15.0.4",
    "lodash-es": "^4.18.1",
    "memfs": "^4.57.2",
    "openapi-typescript": "^7.13.0",
    "ora": "^9.4.0",
    "prettier": "^3.8.3",
    "swagger2openapi": "^7.0.8"
  },
  "devDependencies": {
    "@0x-jerry/x-release": "^3.0.5",
    "@types/fs-extra": "^11.0.4",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.6.0",
    "@types/swagger2openapi": "^7.0.4",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "axios": "^1.6.7",
    "ky": "^1.2.0",
    "oxfmt": "^0.47.0",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.3",
    "vitest": "4.1.5"
  }
}